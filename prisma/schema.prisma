// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          SystemRole @default(USER)
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum SystemRole {
  ADMIN
  CONTADOR
  VENDEDOR
  USER
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Multitenancy Models
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        SubscriptionPlan @default(FREE)
  members     Membership[]
  clients     Client[]
  products    Product[]
  categories  Category[]
  invoices    Invoice[]
  estimates   Estimate[]
  expenses    Expense[]
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

model Role {
  id             String       @id @default(cuid())
  name           String
  description    String?
  permissions    String[]     // E.g., ["sales:view", "sales:create", "contacts:view"]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    Membership[] // Users who hold this role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, organizationId])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  
  // The original enum field is replaced by 'systemRole'
  systemRole     SystemRole   @default(USER)
  
  // Optional, as a user might not have a custom role assigned
  roleId         String? 
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull) // Relation to the new Role model
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

// Business Models
model Client {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  address        String?
  idNumber       String?  // NIT or CC
  type           ContactType @default(CLIENT)
  invoices       Invoice[]
  estimates      Estimate[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, idNumber])
  @@index([organizationId, name])
}

enum ContactType {
  CLIENT
  PROVIDER
  BOTH
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  price          Decimal  @db.Decimal(16, 2)
  stock          Int      @default(0)
  sku            String?
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  invoiceItems   InvoiceItem[]
  estimateItems  EstimateItem[]
  expenseItems   ExpenseItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId, name])
}

model Category {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  type           CategoryType @default(PRODUCT)
  products       Product[]
  expenses       Expense[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
}

enum CategoryType {
  PRODUCT
  EXPENSE
  SERVICE
}

model Invoice {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  number         String
  date           DateTime    @default(now())
  dueDate        DateTime?
  clientId       String
  client         Client      @relation(fields: [clientId], references: [id])
  items          InvoiceItem[]
  payments       Payment[]
  subtotal       Decimal     @db.Decimal(16, 2)
  tax            Decimal     @db.Decimal(16, 2)
  total          Decimal     @db.Decimal(16, 2)
  status         InvoiceStatus @default(DRAFT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([organizationId, date])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String?
  quantity    Int
  price       Decimal @db.Decimal(16, 2)
  total       Decimal @db.Decimal(16, 2)

  @@index([invoiceId])
}

model Estimate {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  number         String
  date           DateTime    @default(now())
  dueDate        DateTime?
  clientId       String
  client         Client      @relation(fields: [clientId], references: [id])
  items          EstimateItem[]
  subtotal       Decimal     @db.Decimal(16, 2)
  tax            Decimal     @db.Decimal(16, 2)
  total          Decimal     @db.Decimal(16, 2)
  status         EstimateStatus @default(DRAFT)
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([organizationId, date])
}

model EstimateItem {
  id          String  @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String?
  quantity    Int
  price       Decimal @db.Decimal(16, 2)
  total       Decimal @db.Decimal(16, 2)

  @@index([estimateId])
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  number         String
  date           DateTime @default(now())
  provider       String
  description    String?
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  items          ExpenseItem[]
  payments       Payment[]
  total          Decimal  @db.Decimal(16, 2)
  status         ExpenseStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([organizationId, date])
}

model ExpenseItem {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  description String?
  quantity  Int
  price     Decimal @db.Decimal(16, 2)
  total     Decimal @db.Decimal(16, 2)

  @@index([expenseId])
}

model Payment {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  amount      Decimal  @db.Decimal(16, 2)
  method      PaymentMethod @default(CASH)
  reference   String?
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  expenseId   String?
  expense     Expense? @relation(fields: [expenseId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  PARTIAL
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  OTHER
}
